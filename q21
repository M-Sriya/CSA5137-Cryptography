#include <stdio.h>
#include <string.h>

int main()
{
    char plaintext[100];
    int blockSize = 8;
    int len, pad;

    printf("Enter plaintext: ");
    fgets(plaintext, sizeof(plaintext), stdin);

    len = strlen(plaintext);

    if(plaintext[len-1]=='\n')
        plaintext[len-1]='\0';

    len = strlen(plaintext);

    pad = blockSize - (len % blockSize);

    if(pad == blockSize)
        pad = 0;

    printf("\nOriginal Length: %d\n", len);
    printf("Padding Required: %d\n", pad);

    printf("\nPadded Message: ");

    printf("%s", plaintext);

    for(int i=0;i<pad;i++)
        printf("0");

    printf("\n");

    return 0;
}
