#include <stdio.h>
#include <ctype.h>

int main() {
    char text[500];
    int freq[26] = {0};

    printf("Enter ciphertext: ");
    scanf(" %[^\n]", text);

    for(int i = 0; text[i] != '\0'; i++) {
        if(isalpha(text[i])) {
            char c = toupper(text[i]);
            freq[c - 'A']++;
        }
    }

    printf("\nLetter Frequency:\n");
    for(int i = 0; i < 26; i++) {
        printf("%c : %d\n", 'A' + i, freq[i]);
    }

    return 0;
}
