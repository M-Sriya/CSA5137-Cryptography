#include <stdio.h>
#include <string.h>
#include <ctype.h>

char matrix[5][5];

void createMatrix(char *key) {
    int used[26] = {0};
    int i, j = 0, k = 0;

    for(i = 0; key[i]; i++) {
        char c = toupper(key[i]);
        if(c == 'J') c = 'I';
        if(!used[c - 'A']) {
            matrix[j][k++] = c;
            used[c - 'A'] = 1;
            if(k == 5) { j++; k = 0; }
        }
    }

    for(i = 0; i < 26; i++) {
        if(i + 'A' == 'J') continue;
        if(!used[i]) {
            matrix[j][k++] = i + 'A';
            if(k == 5) { j++; k = 0; }
        }
    }
}

void findPosition(char c, int *row, int *col) {
    for(int i = 0; i < 5; i++)
        for(int j = 0; j < 5; j++)
            if(matrix[i][j] == c) {
                *row = i;
                *col = j;
            }
}

int main() {
    char key[50], text[200];
    int i;

    printf("Enter key: ");
    scanf("%s", key);

    createMatrix(key);

    printf("Enter plaintext (even length): ");
    scanf("%s", text);

    for(i = 0; text[i]; i += 2) {
        int r1, c1, r2, c2;
        char a = toupper(text[i]);
        char b = toupper(text[i+1]);

        if(a == 'J') a = 'I';
        if(b == 'J') b = 'I';

        findPosition(a, &r1, &c1);
        findPosition(b, &r2, &c2);

        if(r1 == r2) {
            printf("%c%c",
                   matrix[r1][(c1+1)%5],
                   matrix[r2][(c2+1)%5]);
        }
        else if(c1 == c2) {
            printf("%c%c",
                   matrix[(r1+1)%5][c1],
                   matrix[(r2+1)%5][c2]);
        }
        else {
            printf("%c%c",
                   matrix[r1][c2],
                   matrix[r2][c1]);
        }
    }
    printf("\n");
    return 0;
}
