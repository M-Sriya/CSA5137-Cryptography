#include <stdio.h>
#include <string.h>

int main() {
    char text[100], key;

    printf("Enter plaintext: ");
    scanf("%s", text);

    printf("Enter key character: ");
    scanf(" %c", &key);

    printf("Ciphertext (hex): ");
    for(int i = 0; i < strlen(text); i++) {
        char c = text[i] ^ key;  // XOR operation
        printf("%02X ", (unsigned char)c);
    }

    printf("\n");
    return 0;
}
