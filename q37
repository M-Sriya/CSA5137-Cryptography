#include <stdio.h>
#include <ctype.h>

int main()
{
    char text[200];
    int freq[26]={0};

    printf("Enter ciphertext: ");
    fgets(text,200,stdin);

    for(int i=0;text[i]!='\0';i++)
        if(isalpha(text[i]))
            freq[tolower(text[i])-'a']++;

    for(int i=0;i<26;i++)
        printf("%c : %d\n",'A'+i,freq[i]);

    return 0;
}
