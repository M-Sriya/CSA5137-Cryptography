#include <stdio.h>
#include <ctype.h>

char matrix[5][5] = {
    {'M','F','H','I','K'},
    {'U','N','O','P','Q'},
    {'Z','V','W','X','Y'},
    {'E','L','A','R','G'},
    {'D','S','T','B','C'}
};

void findPos(char c, int *r, int *c2) {
    for(int i=0;i<5;i++)
        for(int j=0;j<5;j++)
            if(matrix[i][j]==c){
                *r=i; *c2=j;
            }
}

int main() {
    char text[200];
    int i;

    printf("Enter plaintext (no spaces, even length): ");
    scanf("%s", text);

    for(i=0;text[i];i+=2){
        int r1,c1,r2,c2;
        char a=toupper(text[i]);
        char b=toupper(text[i+1]);

        findPos(a,&r1,&c1);
        findPos(b,&r2,&c2);

        if(r1==r2)
            printf("%c%c",matrix[r1][(c1+1)%5],matrix[r2][(c2+1)%5]);
        else if(c1==c2)
            printf("%c%c",matrix[(r1+1)%5][c1],matrix[(r2+1)%5][c2]);
        else
            printf("%c%c",matrix[r1][c2],matrix[r2][c1]);
    }

    printf("\n");
    return 0;
}
