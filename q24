#include <stdio.h>

int gcd(int a,int b)
{
    while(b!=0)
    {
        int t=b;
        b=a%b;
        a=t;
    }
    return a;
}

int main()
{
    int e=31,n=3599,p,q,phi,d=1;

    for(int i=2;i<n;i++)
    {
        if(n%i==0)
        {
            p=i;
            q=n/i;
            break;
        }
    }

    phi=(p-1)*(q-1);

    while((d*e)%phi!=1)
        d++;

    printf("p = %d\n",p);
    printf("q = %d\n",q);
    printf("phi(n) = %d\n",phi);
    printf("Private Key d = %d\n",d);

    return 0;
}
