#include <stdio.h>

int main()
{
    int p[4], counter[4], k[4], c[4];
    int i;

    printf("Enter 4 plaintext bits:\n");
    for(i=0;i<4;i++)
        scanf("%d",&p[i]);

    printf("Enter 4 key bits:\n");
    for(i=0;i<4;i++)
        scanf("%d",&k[i]);

    printf("Enter counter bits:\n");
    for(i=0;i<4;i++)
        scanf("%d",&counter[i]);

    for(i=0;i<4;i++)
        c[i] = p[i] ^ (counter[i] ^ k[i]);

    printf("\nCiphertext: ");
    for(i=0;i<4;i++)
        printf("%d",c[i]);

    printf("\n");

    return 0;
}
