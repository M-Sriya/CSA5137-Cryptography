#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char text[100];
    int key[100];
    int i, n;

    printf("Enter plaintext (no spaces): ");
    scanf("%s", text);

    n = strlen(text);

    printf("Enter %d key numbers (0-25):\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &key[i]);
    }

    printf("Ciphertext: ");

    for(i = 0; i < n; i++) {
        int p = toupper(text[i]) - 'A';
        int c = (p + key[i]) % 26;
        printf("%c", c + 'A');
    }

    printf("\n");

    return 0;
}
