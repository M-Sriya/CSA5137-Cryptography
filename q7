#include <stdio.h>
#include <string.h>

int main() {
    char cipher[500];
    int freq[256]={0};

    printf("Enter ciphertext: ");
    scanf("%s", cipher);

    for(int i=0; cipher[i]; i++)
        freq[(int)cipher[i]]++;

    printf("\nCharacter Frequencies:\n");
    for(int i=0;i<256;i++)
        if(freq[i]>0)
            printf("%c : %d\n", i, freq[i]);

    return 0;
}
