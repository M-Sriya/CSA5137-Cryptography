#include <stdio.h>

int modInverse(int a) {
    for(int i=0;i<26;i++)
        if((a*i)%26==1)
            return i;
    return -1;
}

int main() {
    int key[2][2] = {{9,4},{5,7}};
    int det = (key[0][0]*key[1][1] - key[0][1]*key[1][0]) % 26;
    if(det < 0) det += 26;

    int invDet = modInverse(det);

    if(invDet == -1) {
        printf("Matrix not invertible\n");
        return 0;
    }

    int inv[2][2];
    inv[0][0] = key[1][1] * invDet % 26;
    inv[1][1] = key[0][0] * invDet % 26;
    inv[0][1] = -key[0][1] * invDet % 26;
    inv[1][0] = -key[1][0] * invDet % 26;

    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            if(inv[i][j] < 0)
                inv[i][j] += 26;

    printf("Inverse Matrix:\n");
    printf("%d %d\n%d %d\n", inv[0][0], inv[0][1], inv[1][0], inv[1][1]);

    return 0;
}
